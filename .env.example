# 翻译模型配置(任选其一)
# MT_PROVIDER 可选值: deepseek / qwen / kimi / zhipu / openai
# 不设置则默认 mock 模式

# --- DeepSeek (推荐,便宜好用) ---
# MT_PROVIDER=deepseek
# LLM_API_KEY=sk-xxx
# 注册: https://platform.deepseek.com

# --- 通义千问 ---
# MT_PROVIDER=qwen
# LLM_API_KEY=sk-xxx
# 注册: https://dashscope.console.aliyun.com

# --- Kimi (月之暗面) ---
# MT_PROVIDER=kimi
# LLM_API_KEY=sk-xxx
# 注册: https://platform.moonshot.cn

# --- 智谱 GLM ---
# MT_PROVIDER=zhipu
# LLM_API_KEY=xxx
# 注册: https://open.bigmodel.cn

# --- OpenAI ---
# MT_PROVIDER=openai
# LLM_API_KEY=sk-xxx

# --- 自定义兼容接口 ---
# MT_PROVIDER=custom
# LLM_BASE_URL=https://your-endpoint/v1
# LLM_MODEL=your-model
# LLM_API_KEY=xxx

# ASR 语音识别(暂用 mock)
# ASR_PROVIDER=deepgram
# DEEPGRAM_API_KEY=xxx
