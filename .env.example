# ============================================================
# AI 同声传译助手 - 环境变量配置
# 复制此文件为 server/.env 并填入你的 API Key
# ============================================================

# ---------- 翻译 LLM（必填）----------
# MT_PROVIDER 可选: deepseek / qwen / kimi / zhipu / openai
MT_PROVIDER=deepseek
LLM_API_KEY=sk-xxx

# DeepSeek: https://platform.deepseek.com
# 通义千问: https://dashscope.console.aliyun.com
# Kimi:     https://platform.moonshot.cn
# 智谱 GLM: https://open.bigmodel.cn
# OpenAI:   https://platform.openai.com

# 自定义兼容接口:
# MT_PROVIDER=custom
# LLM_BASE_URL=https://your-endpoint/v1
# LLM_MODEL=your-model

# ---------- ASR 语音识别（推荐配置）----------
# ASR_PROVIDER 可选: siliconflow / groq / openai
# 不配置则降级为浏览器 Web Speech API（需 Chrome + 可访问 Google）
ASR_PROVIDER=siliconflow
ASR_API_KEY=xxx

# SiliconFlow: https://siliconflow.cn (SenseVoiceSmall)
# Groq:        https://console.groq.com (whisper-large-v3, 免费)
# OpenAI:      https://platform.openai.com (whisper-1)

# ---------- TTS 语音合成（可选）----------
# TTS_PROVIDER 可选: siliconflow / openai
# 不配置则用浏览器自带 speechSynthesis
# SiliconFlow CosyVoice 支持声音克隆
TTS_PROVIDER=siliconflow
TTS_API_KEY=xxx

# 可选自定义:
# TTS_BASE_URL=https://api.siliconflow.cn/v1
# TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
# TTS_VOICE=中文女

# ---------- 服务端口 ----------
# PORT=8787
